#Service Name
Name       = PTIntegrationApi

Host=192.168.38.47
PORT=4100

#0 if http  1 if HTTPS
HTTPS         = 0    

#0 to dont save the request raw data  1 if wanna save the request raw data
SAVEREQUEST   = 0

#Logs
#XmlPath= /mnt/packetalk/kearnygenetec/xml/
#RequestPath= /mnt/packetalk/kearnygenetec/request/
#LogPath     = /mnt/packetalk/kearnygenetec/logs/
DatePattern = yyyyMMdd   # eg. yyyy-MM-dd-hh


XmlPath= /mnt/packetalk/xml/
RequestPath= /mnt/packetalk/request/
LogPath     = /mnt/packetalk/logs/


# Certificates for HTTPS
# _KEY  = '/usr/local/node/key'
# _CERT = '/usr/local/node/cert.pem'

_KEY  = '/usr/local/node/key'
_CERT = '/usr/local/node/cert.pem'



